{
	"info": {
		"name": "BTG Funds API",
		"description": "Colección de Postman para la API de gestión de fondos de inversión BTG Pactual",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login (ADMIN)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.data.token);",
									"    pm.test('Token guardado', function () {",
									"        pm.expect(jsonData.data.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						}
					}
				},
				{
					"name": "Login (USER)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.data.token);",
									"    pm.test('Token guardado', function () {",
									"        pm.expect(jsonData.data.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"user\",\n    \"password\": \"user123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						}
					}
				},
				{
					"name": "Registrar usuario",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"usuario1\",\n    \"password\": \"pass123\",\n    \"email\": \"usuario1@email.com\",\n    \"role\": \"USER\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					}
				}
			]
		},
		{
			"name": "Fondos",
			"item": [
				{
					"name": "Listar fondos",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/funds",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "funds"]
						}
					}
				}
			]
		},
		{
			"name": "Suscripciones",
			"item": [
				{
					"name": "Suscribirse a un fondo",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"clientId\": 1,\n    \"fundId\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/subscriptions",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "subscriptions"]
						}
					}
				},
				{
					"name": "Cancelar suscripción",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"clientId\": 1,\n    \"fundId\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/subscriptions",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "subscriptions"]
						}
					}
				},
				{
					"name": "Ver suscripciones activas",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/subscriptions/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "subscriptions", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Transacciones",
			"item": [
				{
					"name": "Ver historial de transacciones",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/transactions/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transactions", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Clientes (Solo ADMIN)",
			"item": [
				{
					"name": "Ver información del cliente",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/clients/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "clients", "1"]
						}
					}
				}
			]
		}
	]
}
